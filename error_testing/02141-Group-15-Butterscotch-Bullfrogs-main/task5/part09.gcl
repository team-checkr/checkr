// Another finite summation *** Done P
{ n >= 1 }
r := 0 ;
{ n >= 1 & r = 0}
i := 0 ;
{ n >= 1 & r = 0 & i = 0}
do[r = i * (i + 1) & i <= n] // TODO: replace `false` by a suitable invariant
  i < n ->
    {r + 2*(i+1)= (i+1) * (i + 2) & (i+1) <= n}
    i := i + 1 ;
    {r + 2*i= i * (i + 1) & i <= n}
    r := r + 2*i 
    {r = i * (i + 1) & i <= n}
od
{ r = n * (n + 1)}