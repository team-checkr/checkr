{ x = x0 + 10*x1 + 100*x2
 & (a0 = 0 | a0 = 1) & (a1 = 0 | a1 = 1) & (a2 = 0 | a2 = 1) }
i := 0;
{ x = x0 + 10*x1 + 100*x2
 & (a0 = 0 | a0 = 1) & (a1 = 0 | a1 = 1) & (a2 = 0 | a2 = 1)
 & i = 0 }
a := 0;
{ x = x0 + 10*x1 + 100*x2
 & (a0 = 0 | a0 = 1) & (a1 = 0 | a1 = 1) & (a2 = 0 | a2 = 1)
 & i = 0 & a = 0}
do[0 <= i & i <= 3 &  (
  (i = 0 & a = 0) | 
  (i = 1 & a = a0*x0) | 
  (i = 2 & a = a0*x0 + a1*10*x1) | 
  (i = 3 & a = a0*x0 + a1*10*x1 + a2*100*x2))  
 ] // TODO: replace `false` by a suitable invariant
  i <= 2 -> 
  {i <= 2 &
  (i = 0 & a = 0) | 
  (i = 1 & a = a0*x0) | 
  (i = 2 & a = a0*x0 + a1*10*x1) | 
  (i = 3 & a = a0*x0 + a1*10*x1 + a2*100*x2)}
    if 
      i = 0 -> 
      {i = 0 & a = 0}
      a := a + a0*x0
      {(i = 0 & i+1 = 1 & a = a0*x0)}
      []
      i = 1 -> 
      {i = 1 & a = a0*x0}
      a := a + a1*10*x1
      {(i = 1 & i+1 = 2 & a = a0*x0 + a1*10*x1)}
      []
      i = 2 -> 
      {i = 2 & a = a0*x0 + a1*10*x1}
      a := a + a2*100*x2
      {(i = 2 & i+1 = 3 & a = a0*x0 + a1*10*x1 + a2*100*x2)}
    fi ;
    {(i = 0 & a = a0*x0) | (i = 1 & a = a0*x0 + a1*10*x1) | (i = 2 & a = a0*x0 + a1*10*x1 + a2*100*x2)}
    i := i + 1
    {0 <= i & i <= 3 &  (
  (i = 0 & a = 0) | 
  (i = 1 & a = a0*x0) | 
  (i = 2 & a = a0*x0 + a1*10*x1) | 
  (i = 3 & a = a0*x0 + a1*10*x1 + a2*100*x2)
)}
od
