// Bounded exponential *** Done P
{ 1 < e }
r := 1;
{ 1 < e & r=1 }
i := 0;
{ 1 < e & r=1 & i=0}
do[r = exp(e, i) &  0 <= i & r < 256 & r >= 1  & 1 < e ] // TODO: replace `false` by a suitable invariant
  r * e < 256 ->
    {r * e= exp(e, i+1) &  0 <= i+1  & r*e < 256 & r >= 1 & 1 < e}
    r := e * r;
    {r = exp(e, i+1) &  0 <= i+1  & r < 256 & r >= 1 & 1 < e}
    i := i + 1
    {r = exp(e, i) &  0 <= i  & r < 256 & r >= 1 & 1 < e}
od
{ r = exp(e, i) & r < 256 & r * e >= 256} 
