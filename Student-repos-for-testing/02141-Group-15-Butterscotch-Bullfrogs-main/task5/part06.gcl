// Efficient cubes *** Done P
{ 0 <= n }
r := 0;
{ 0 <= n & r = 0}
i := 0;
{ 0 <= n & r = 0 & i = 0}
s := 0;
{ 0 <= n & r = 0 & i = 0 & s=0}
t := 0;
{ 0 <= n & r = 0 & i = 0 & s=0 & t = 0 }
do[r =i*i*i & 0 <= i & i <= n & t = 3*i & s = 3*i*i ] // TODO: replace `false` by a suitable invariant
  i < n -> 
  {r + s + t + 1 =(i+1)*(i+1)*(i+1) & 0 <= (i+1) & (i+1) <= n & t+3 = 3*(i+1) & s + 2 * t + 3 = 3*(i+1)*(i+1) }
    r := r + s + t + 1;
    {r =(i+1)*(i+1)*(i+1) & 0 <= (i+1) & (i+1) <= n & t+3 = 3*(i+1) & s + 2 * t + 3 = 3*(i+1)*(i+1) }
    s := s + 2 * t + 3;
    {r =(i+1)*(i+1)*(i+1) & 0 <= (i+1) & (i+1) <= n & t+3 = 3*(i+1) & s = 3*(i+1)*(i+1) }
    t := t + 3;
    {r =(i+1)*(i+1)*(i+1) & 0 <= (i+1) & (i+1) <= n & t = 3*(i+1) & s = 3*(i+1)*(i+1) }
    i := i + 1
    {r =i*i*i & 0 <= i & i <= n & t = 3*i & s = 3*i*i }
od
{ r = n*n*n }