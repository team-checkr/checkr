// Computing exponentials *** Done P
{ 0 <= n & 1 < e }
r := 1;
{ 0 <= n & 1 < e & r = 1}
i := 0;
{ 0 <= n & 1 < e & r = 1 & i = 0}
do [r = exp(e, i) & 0 <= i & i <= n] // TODO: replace `false` by a suitable invariant
  i < n ->
   {r = exp(e, i) & 0 <= i & i < n}
    r := e * r;
    {r = exp(e, i+1) & 0 <= i+1 & i+1 <= n}
    i := i + 1
    {r = exp(e, i) & 0 <= i & i <= n}
od
{ r = exp(e, n) }