// Open the file that defines the type "expr" we shall use as AST
%{
open AST
%}

// Declare the tokens (terminal symbols)
%token <bigint> NUM
%token <string> VAR
%token TIMES DIV PLUS MINUS POW LPAR RPAR EOF
%token LBRACKET RBRACKET                        // [ ]  for arrays
%token ASSIGN                                   // :=
%token SEMI                                     // ;
%token ARROW                                    // ->
%token CHOICE                                   // []
%token IF FI DO OD SKIP
%token TRUE FALSE
%token AND OR ANDAND OROR NOT                   // & | && || !
%token EQ NEQ GT GTE LT LTE                     // = != > >= < <=
// NOTE: the actual formats of these tokens are defined in the lexer file
//       as regular expressions

// Specify precedence and associativity of operators
// Precedence is given by the order (from low to high)
%left PLUS MINUS
%left TIMES DIV
%right POW
%nonassoc UMINUS

//Bool precedence (low -> high)
%left OROR OR
%left ANDAND AND
%nonassoc NOT

//Command / GC assocoativity
%right SEMI
%right CHOICE


// We declare the initial non-terminal symbol
%start start_commands
%start start_expression

// We specify the return type of each of then non-terminal symbols
%type <AST.command> start_commands
%type <AST.expr> start_expression
%type <AST.expr> expr
%type <AST.command> command
%type <AST.gc> gc
%type <AST.bexpr> bexpr 

// Grammar productions
%%

// The first production in "formal" notation is
// start_expression -> expr
// here written:
start_expression: expr EOF            { $1 }
//for GCL and parser                  
start_commands:
    | command EOF                           { $1 }
// Note that we need to insert an End-Of-File (EOF)
// The code annotation { $1 } specifies that parsing with this production
// returns whatever parsing the expression returns: $1 is the result of parsing
// the first component of the production (i.e. expression)

// The productions for expressions are like in the grammar we saw in class
// written in the yacc format:
command:
    | VAR ASSIGN expr                       { Assign($1, $3) }
    | VAR LBRACKET expr RBRACKET ASSIGN expr { ArrAssign($1, $3, $6) }
    | SKIP                                  { Skip }
    | command SEMI command                  { Seq($1, $3) }
    | IF gc FI                              { If($2) }
    | DO gc OD                              { Do($2) }

gc:
    | bexpr ARROW command                   { Guard($1, $3) }
    | gc CHOICE gc                          { GCChoice($1, $3) }

expr:
    | NUM                                   { Num($1) }
    | VAR                                   { Var($1) }
    | VAR LBRACKET expr RBRACKET            { Array($1, $3) }
    | expr PLUS expr                        { PlusExpr($1, $3) }
    | expr MINUS expr                       { MinusExpr($1, $3) }
    | expr TIMES expr                       { TimesExpr($1, $3) }
    | expr DIV expr                         { DivExpr($1, $3) }
    | expr POW expr                         { PowExpr($1, $3) }
    | MINUS expr %prec UMINUS               { UMinusExpr($2) }
    | LPAR expr RPAR                        { $2 }

bexpr:
    | TRUE                                  { True }
    | FALSE                                 { False }
    | bexpr AND bexpr                       { AndExpr($1, $3) }
    | bexpr OR bexpr                        { OrExpr($1, $3) }
    | bexpr ANDAND bexpr                    { AndAndExpr($1, $3) }
    | bexpr OROR bexpr                      { OrOrExpr($1, $3) }
    | NOT bexpr                             { NotExpr($2) }
    | expr EQ expr                          { EqExpr($1, $3) }
    | expr NEQ expr                         { NeqExpr($1, $3) }
    | expr GT expr                          { GtExpr($1, $3) }
    | expr GTE expr                         { GteExpr($1, $3) }
    | expr LT expr                          { LtExpr($1, $3) }
    | expr LTE expr                         { LteExpr($1, $3) }
    | LPAR bexpr RPAR                       { $2 }

// Again, the code annotation specifies the result of parsing
// For example { TimesExpr($1,$3) } specifies that parsing with the production
// returns the value TimesExpr($1,$3), where $i is the result of parsing
// component i in the production (in this case the lhs and rhs operands)

%%
