// Distributing and rebuilding a secret
{ x = x0 + 10*x1 + 100*x2
 & (a0 = 0 | a0 = 1) & (a1 = 0 | a1 = 1) & (a2 = 0 | a2 = 1)
 & (b0 = 0 | b0 = 1) & (b1 = 0 | b1 = 1) & (b2 = 0 | b2 = 1)
 & (c0 = 0 | c0 = 1) & (c1 = 0 | c1 = 1) & (c2 = 0 | c2 = 1)
 & (a0+b0+c0 = 1) 
 & (a1+b1+c1 = 1)
 & (a2+b2+c2 = 1)
 }
a := a0*x0 + a1*10*x1 + a2*100*x2;
{ a + b0*x0 + b1*10*x1 + b2*100*x2 + c0*x0 + c1*10*x1 + c2*100*x2 = x }
b := b0*x0 + b1*10*x1 + b2*100*x2;
{ a + b + c0*x0 + c1*10*x1 + c2*100*x2 = x }
c := c0*x0 + c1*10*x1 + c2*100*x2
{ a + b + c = x }