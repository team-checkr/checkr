// Bounded exponential
{ 1 < e }
r := 1;
{ 1 < e  & r = 1}
i := 0;
{ 1 < e  & r = 1 & i = 0}
do[i >= 0 & r = exp(e, i) & r < 256] 
  r * e < 256 ->
    {i+1 >= 0 & (e * r) = exp(e, i+1) & e * r < 256}  
    r := e * r;
    {i+1 >= 0 & r = exp(e, i+1) & r < 256}
    i := i + 1
    {i >= 0 & r = exp(e, i) & r < 256}
od
{r = exp(e, i) & r < 256 & r * e >= 256} 