// Efficient cubes
{ 0 <= n }
r := 0;
{r = 0 & n>=0}
i := 0;
{r = 0 & i = 0 & n>=0}
s := 0;
{r = 0 & i = 0 & s = 0 & n>=0}
t := 0;
{r = 0 & i = 0 & s = 0 & t = 0 & n>=0}
do[i <= n & t = 3*i & s = 3*i*i & r = i*i*i]
  i < n -> 
    {i+1 <= n & r = i*i*i & s = 3*i*i & t = 3 *i}
    r := r + s + t + 1;
    {i+1 <= n & r = (i+1) * (i+1) * (i+1) & s = 3*i*i & t = 3*i}
    s := s + 2 * t + 3;
    {i+1 <= n & r = (i+1) * (i+1) * (i+1) & s = 3 * (i+1) * (i+1) & t = 3*i}
    t := t + 3;
    {i+1 <= n & r = (i+1) * (i+1) * (i+1) & s = 3 * (i+1) * (i+1) & t = 3 * (i+1)}
    i := i + 1
    {i <= n & r = i*i*i & t = 3*i & s = 3*i*i & r = i*i*i}
od
{ r = n*n*n }
