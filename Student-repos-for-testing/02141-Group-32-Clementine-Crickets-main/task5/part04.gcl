// Computing exponentials
{ 0 <= n & 1 < e }
r := 1 { 0 <= n & 1 < e & r = 1};
i := 0 { 0 <= n & 1 < e & r = 1 & i = 0};
{i = 0 & i <= n & i >= 0 & r = 1 & r = exp(e,i)}
do[i <= n & r = exp(e,i) & i >= 0]
  i < n -> {i <= n & r = exp(e,i) & i >= 0 & i < n}
    r := e * r;
    {(i+1) <= n & r = exp(e,(i+1)) & (i+1) >= 0}
    i := i + 1
    {i <= n & r = exp(e,i) & i >= 0}
od
{i <= n & r = exp(e,i) & i >= 0 & !(i<n) & i = n}
{ r = exp(e, n) }
