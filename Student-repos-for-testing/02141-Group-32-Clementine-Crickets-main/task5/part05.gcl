// Fibonacci numbers
{ 0 <= n }
r := 0;
{ 0 <= n & r = 0}
s := 1;
{ 0 <= n & r = 0 & s = 1}
i := 0;
{ 0 <= n & r = 0 & s = 1 & i = 0}
do[i <= n & r = fib(i) & s = fib(i+1) & i >= 0] // TODO: replace `false` by a suitable invariant
  i != n -> 
    {(i + 1) <= n & s = fib((i+1)) & (r+s) = fib((i+1)+1) & (i + 1) >= 0} 
    t := s;
    {(i + 1) <= n & t = fib((i+1)) & (r+s) = fib((i+1)+1) & (i + 1) >= 0} 
    s := r + s;
    {(i + 1) <= n & t = fib((i+1)) & s = fib((i+1)+1) & (i + 1) >= 0} 
    r := t;
    {(i + 1) <= n & r = fib((i+1)) & s = fib((i+1)+1) & (i + 1) >= 0} 
    i := i + 1
    {i <= n & r = fib(i) & s = fib(i+1) & i >= 0}    
od
{ r = fib(n) }  